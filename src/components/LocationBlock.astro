---
import { t, type Lang, localizedPath } from '~/i18n';

interface Props { lang?: Lang }
const { lang = 'es' } = Astro.props;

const MAP_EMBED = "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3424.7409753491656!2d-64.52738632470985!3d-30.865926269856615!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x942d8df5395e1ead%3A0xa4dc4f4097366c7f!2sR%C3%ADo%20Negro%2064%2C%20X5184%20Capilla%20del%20Monte%2C%20C%C3%B3rdoba!5e0!3m2!1ses!2sar!4v1779458249290!5m2!1ses!2sar";
const kicker = lang === 'en' ? '01 · LOCATION' : '01 · UBICACIÓN';
const centro = lang === 'en' ? 'Town center · 800 m' : 'Centro · 800 m';
const terminal = lang === 'en' ? 'Bus terminal · 1 km' : 'Terminal · 1 km';
const uritorco = lang === 'en' ? 'Uritorco · 2.3 km' : 'Uritorco · 2,3 km';
---
<section class="location">
  <iframe
    class="loc-map"
    src={MAP_EMBED}
    loading="lazy"
    allowfullscreen
    referrerpolicy="no-referrer-when-downgrade"
    title="Rio Negro 64, Capilla del Monte"
  ></iframe>

  <article class="loc-card frame-card" data-reveal>
    <span class="kicker">{kicker}</span>
    <h3>{t('location.title', lang)}</h3>
    <p>{t('location.lead', lang)}</p>
    <div class="loc-chips">
      <span class="chip">{centro}</span>
      <span class="chip">{terminal}</span>
      <span class="chip">{uritorco}</span>
    </div>
    <a href={localizedPath('/ubicacion', lang)} class="link-acc">{t('location.howToGet', lang)} →</a>
  </article>

  <div class="loc-pin" data-reveal style="transition-delay: 120ms;">
    <span class="kicker">📍 RIO NEGRO 64</span><br/>
    <span>CAPILLA DEL MONTE, CÓRDOBA</span>
  </div>
</section>

<style>
  .location {
    position: relative;
    min-height: 480px;
    background-color: var(--mf-paper-2);
    border-bottom: 1.5px solid var(--mf-ink);
    overflow: hidden;
  }
  .loc-map {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
    z-index: 1;
    display: block;
  }
  .loc-card {
    position: absolute;
    left: 32px;
    top: 32px;
    background: var(--mf-paper);
    padding: 24px 26px;
    max-width: 360px;
    z-index: 3;
  }
  .loc-card h3 {
    font-size: 28px;
    line-height: 1.1;
    margin: 12px 0 10px;
    letter-spacing: -0.02em;
  }
  .loc-card p {
    font-size: 13.5px;
    line-height: 1.55;
    color: var(--mf-ink-soft);
    margin: 0 0 16px;
  }
  .loc-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 16px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--mf-hair);
  }
  .loc-pin {
    position: absolute;
    right: 32px;
    bottom: 32px;
    z-index: 3;
    background: var(--mf-paper);
    border: 1px solid var(--mf-ink);
    padding: 12px 16px;
    font-family: var(--mf-font-mono);
    font-size: 10.5px;
    line-height: 1.6;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  @media (max-width: 720px) {
    .location {
      position: static;
      min-height: auto;
      padding: 0;
    }
    .loc-map {
      position: static;
      width: 100%;
      height: 320px;
    }
    .loc-card {
      position: static;
      max-width: none;
      margin: 18px;
    }
    .loc-pin {
      position: static;
      margin: 0 18px 18px;
      display: inline-block;
    }
  }
</style>
