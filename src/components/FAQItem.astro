---
interface Props { no: string; q: string; a: string; open?: boolean }
const { no, q, a, open = false } = Astro.props;
---
<details class="faq-item" open={open}>
  <summary>
    <span class="faq-no">{no}</span>
    <span class="faq-q">{q}</span>
    <span class="faq-toggle" aria-hidden="true">+</span>
  </summary>
  <div class="faq-a">{a}</div>
</details>

<style>
  .faq-item {
    border-bottom: 1px solid var(--mf-hair);
    cursor: pointer;
  }
  .faq-item summary {
    list-style: none;
    display: flex;
    align-items: baseline;
    gap: 16px;
    padding: 20px 28px;
    font-size: 16px;
    font-weight: 500;
    line-height: 1.3;
    letter-spacing: -0.005em;
  }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-no {
    font-family: var(--mf-font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.1em;
    color: var(--mf-ink-soft);
    min-width: 24px;
  }
  .faq-q { flex: 1; }
  .faq-toggle {
    font-size: 22px;
    font-weight: 300;
    color: var(--mf-ink-soft);
    line-height: 1;
    transition: transform 0.2s, color 0.2s;
  }
  .faq-item[open] .faq-toggle {
    transform: rotate(45deg);
    color: var(--mf-accent);
  }
  .faq-a {
    padding: 0 28px 22px 68px;
    font-size: 14px;
    line-height: 1.6;
    color: var(--mf-ink-soft);
    max-width: 65ch;
    opacity: 0;
    transform: translateY(-4px);
    transition: opacity 0.22s ease, transform 0.22s ease;
  }
  .faq-item[open] .faq-a {
    opacity: 1;
    transform: none;
  }
  @media (max-width: 720px) {
    .faq-item summary { padding: 16px 18px; font-size: 14px; gap: 12px; }
    .faq-a { padding: 0 18px 18px 50px; font-size: 12.5px; }
  }
</style>
