---
import { t, type Lang, localizedPath } from '~/i18n';
import type { CollectionEntry } from 'astro:content';

interface Props {
  unit: CollectionEntry<'unidades'>;
  lang?: Lang;
  align?: 'left' | 'right';
}
const { unit, lang = 'es', align = 'left' } = Astro.props;
const { data } = unit;
const name = lang === 'en' && data.name_en ? data.name_en : data.name;
const blurb = lang === 'en' && data.blurb_en ? data.blurb_en : data.blurb;
const urlSlug = unit.slug.split('/').pop();
const href = localizedPath(`/unidades/${urlSlug}`, lang);
const num = `0${data.order}`;
---
<article class={`unit unit-${align}`} data-reveal>
  <a href={href} class="unit-image" aria-label={name}>
    <img src={data.hero_image} alt={`${name} — departamento de alquiler temporario en Capilla del Monte`} loading="lazy" decoding="async" width="1200" height="900" />
    <span class="unit-caption">{name}</span>
  </a>
  <div class="unit-body">
    <span class="unit-no display-no display-xl">{num}</span>
    <div class="unit-content">
      <header>
        <h3 class="unit-title">{name}</h3>
        <div class="unit-spec">
          <span>{data.specs.capacidad}</span>
          <span aria-hidden="true">·</span>
          <span>{data.specs.metros}</span>
          {data.specs.vista && <><span aria-hidden="true">·</span><span>{data.specs.vista}</span></>}
        </div>
      </header>
      <p class="unit-blurb">{blurb}</p>
      <div class="unit-foot">
        <div class="unit-chips">
          {data.chips.slice(0, 4).map(c => <span class="chip">{c}</span>)}
          <a href={href} class="chip chip-more" aria-label={t('unit.viewMore', lang)}>+</a>
        </div>
        <a href={href} class="link-acc">{t('unit.viewMore', lang)} →</a>
      </div>
    </div>
  </div>
</article>

<style>
  .unit {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    border-bottom: 1px solid var(--mf-hair);
    background: var(--mf-paper);
  }
  .unit-right { direction: rtl; }
  .unit-right > * { direction: ltr; }

  .unit-image {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--mf-stone);
    display: block;
  }
  .unit-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }
  .unit-image:hover img { transform: scale(1.03); }
  .unit-caption {
    position: absolute;
    left: 14px;
    bottom: 14px;
    padding: 6px 10px;
    background: rgba(27, 26, 22, 0.55);
    backdrop-filter: blur(8px);
    color: var(--mf-paper);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: -0.005em;
  }

  .unit-body {
    display: flex;
    gap: 24px;
    padding: 36px 32px;
    align-items: stretch;
  }
  .unit-no {
    flex-shrink: 0;
    width: 130px;
  }
  .unit-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 18px;
    min-width: 0;
  }
  .unit-title {
    font-size: 38px;
    line-height: 1;
    letter-spacing: -0.025em;
    font-weight: 700;
  }
  .unit-spec {
    margin-top: 10px;
    font-family: var(--mf-font-mono);
    font-size: 11.5px;
    font-weight: 500;
    letter-spacing: 0.1em;
    color: var(--mf-ink-soft);
    text-transform: uppercase;
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }
  .unit-blurb {
    font-size: 15px;
    line-height: 1.55;
    color: var(--mf-ink);
    max-width: 55ch;
    margin: 0;
  }
  .unit-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
    flex-wrap: wrap;
  }
  .unit-chips { display: flex; gap: 8px; flex-wrap: wrap; align-items: center; }
  .chip-more {
    width: 30px;
    padding: 0;
    justify-content: center;
    font-size: 16px;
    font-weight: 500;
    line-height: 1;
    color: var(--mf-ink-soft);
    text-decoration: none;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
  }
  .chip-more:hover {
    background: var(--mf-ink);
    color: var(--mf-paper);
    border-color: var(--mf-ink);
  }

  @media (max-width: 900px) {
    .unit, .unit-right { grid-template-columns: 1fr; direction: ltr; }
    .unit-body { padding: 22px 18px; gap: 14px; flex-direction: column; }
    .unit-no { width: auto; }
    .unit-title { font-size: 28px; }
  }

  @media (max-width: 480px) {
    .unit-body { padding: 20px 16px; gap: 12px; }
    .unit-no { font-size: 44px; }
    .unit-title { font-size: 24px; }
    .unit-blurb { font-size: 14px; }
    .unit-caption { left: 10px; bottom: 10px; font-size: 10.5px; padding: 5px 9px; }
  }
</style>
