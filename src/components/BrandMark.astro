---
interface Props {
  inverted?: boolean;
  size?: number;
  class?: string;
}
const { size = 36, class: cls = '' } = Astro.props;
---
<img
  src="/logo-refugio.jpeg"
  alt="Refugio del Corazón"
  class={`brand-mark-img ${cls}`}
  width={size}
  height={size}
  style={`width:${size}px;height:${size}px;`}
/>

<style>
  .brand-mark-img {
    display: inline-block;
    object-fit: cover;
    border-radius: 999px;
    flex-shrink: 0;
  }
</style>
