---
import WhatsAppCTA from './WhatsAppCTA.astro';
import { t, type Lang } from '~/i18n';

interface Props {
  lang?: Lang;
  image?: string;
  kicker?: string;
  title?: string;
  subtitle?: string;
}
const {
  lang = 'es',
  image = '/cerro%20uritorco.jpg',
  kicker,
  title,
  subtitle,
} = Astro.props;

const k = kicker ?? t('hero.kicker', lang);
const ti = title ?? t('hero.title', lang);
const sub = subtitle ?? t('hero.subtitle', lang);
---
<section class="hero">
  <div class="hero-bg" style={`background-image:url('${image}');`}></div>
  <div class="hero-overlay"></div>

  <div class="hero-top">
    <span class="hero-meta">Rio Negro 64 · Capilla del Monte</span>
  </div>

  <div class="hero-body">
    <span class="hero-kicker">{k}</span>
    <h1 class="hero-title">{ti}</h1>
    <div class="hero-bottom">
      <p class="hero-sub">{sub}</p>
      <WhatsAppCTA lang={lang} variant="big" />
    </div>
  </div>

  <div class="hero-foot">
    <span>↓ {t('hero.scrollHint', lang)}</span>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 720px;
    color: var(--mf-paper);
    display: flex;
    flex-direction: column;
    background-color: var(--mf-ink);
    border-bottom: 1.5px solid var(--mf-ink);
    padding-top: 80px;
    overflow: hidden;
    isolation: isolate;
  }

  .hero-bg {
    position: absolute;
    inset: -20px;
    background-size: cover;
    background-position: center;
    filter: blur(10px) brightness(0.7) saturate(0.9);
    transform: scale(1.08);
    z-index: -2;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg,
        rgba(27, 26, 22, 0.55) 0%,
        rgba(27, 26, 22, 0.25) 30%,
        rgba(27, 26, 22, 0.35) 55%,
        rgba(27, 26, 22, 0.75) 100%);
    z-index: -1;
  }

  .hero-top {
    display: flex;
    justify-content: space-between;
    padding: 22px 28px;
    border-bottom: 1px solid rgba(244, 240, 230, 0.15);
    font-family: var(--mf-font-mono);
    font-size: 10.5px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    opacity: 0.85;
  }

  .hero-body {
    flex: 1;
    padding: 0 28px 30px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: 24px;
  }

  @keyframes heroIn {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: var(--mf-hero-final-opacity, 1); transform: none; }
  }

  .hero-kicker,
  .hero-title,
  .hero-sub,
  .hero-bottom {
    opacity: 0;
    animation: heroIn 0.55s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  .hero-kicker { --mf-hero-final-opacity: 0.9; animation-delay: 40ms; }
  .hero-title  { animation-delay: 140ms; }
  .hero-sub    { --mf-hero-final-opacity: 0.92; animation-delay: 260ms; }
  .hero-bottom { animation-delay: 320ms; }

  .hero-kicker {
    font-family: var(--mf-font-mono);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .hero-title {
    font-size: clamp(64px, 9vw, 156px);
    line-height: 0.86;
    letter-spacing: -0.045em;
    font-weight: 800;
    max-width: 14ch;
  }

  .hero-bottom {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 30px;
    flex-wrap: wrap;
    margin-top: 8px;
  }
  .hero-sub {
    font-size: 16px;
    line-height: 1.5;
    max-width: 480px;
    margin: 0;
  }

  .hero-foot {
    display: flex;
    gap: 14px;
    align-items: center;
    justify-content: space-between;
    padding: 14px 28px;
    border-top: 1px solid rgba(244, 240, 230, 0.15);
    font-family: var(--mf-font-mono);
    font-size: 10.5px;
    font-weight: 500;
    letter-spacing: 0.14em;
    opacity: 0.85;
    text-transform: uppercase;
  }

  @media (max-width: 720px) {
    .hero { min-height: 600px; padding-top: 64px; }
    .hero-top { padding: 14px 18px; font-size: 9px; }
    .hero-body { padding: 0 18px 24px; gap: 18px; }
    .hero-title { font-size: clamp(52px, 14vw, 80px); max-width: 100%; }
    .hero-sub { font-size: 14px; max-width: 30ch; }
    .hero-bottom { gap: 20px; }
    .hero-foot { padding: 12px 18px; font-size: 9px; }
  }

  @media (max-width: 380px) {
    .hero-title { font-size: clamp(44px, 13.5vw, 56px); }
    .hero-top span { font-size: 8.5px; }
  }
</style>
