---
import { t, type Lang } from '~/i18n';

interface ServiceItem { k: string; v?: string }
interface Props {
  lang?: Lang;
  items?: ServiceItem[];
  columns?: 1 | 2;
}

const defaultItems: ServiceItem[] = [
  { k: 'WiFi fibra óptica (300 megas)', v: 'INCLUIDO' },
  { k: 'Cocina equipada + heladera con freezer', v: 'INCLUIDO' },
  { k: 'Ropa de cama y toallas', v: 'INCLUIDO' },
  { k: 'Cochera privada (sujeto a disponibilidad)', v: 'INCLUIDO' },
  { k: 'Aire acondicionado', v: 'INCLUIDO' },
  { k: 'Parrilla', v: 'INCLUIDO' },
  { k: 'Patio interno compartido', v: 'INCLUIDO' },
  { k: 'Check-in con anfitrión', v: 'INCLUIDO' },
  { k: 'Smart TV con streaming', v: 'INCLUIDO' },
];

const { lang = 'es', items = defaultItems, columns = 2 } = Astro.props;
---
<div class={`serv-grid cols-${columns}`}>
  {items.map(it => (
    <div class="serv-row">
      <span class="d-dot"></span>
      <span class="serv-k">{it.k}</span>
      {it.v && <span class="serv-v">{it.v}</span>}
    </div>
  ))}
</div>

<style>
  .serv-grid {
    padding: 14px 28px 18px;
  }
  .cols-2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    column-gap: clamp(20px, 4vw, 40px);
  }
  .serv-row {
    display: grid;
    grid-template-columns: 14px 1fr auto;
    gap: 12px;
    align-items: baseline;
    padding: 11px 0;
    border-bottom: 1px solid var(--mf-hair);
  }
  .d-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--mf-accent);
    margin-top: 6px;
  }
  .serv-k {
    font-size: 14.5px;
    font-weight: 500;
    letter-spacing: -0.005em;
    line-height: 1.3;
  }
  .serv-v {
    font-family: var(--mf-font-mono);
    font-size: 10.5px;
    font-weight: 500;
    letter-spacing: 0.1em;
    color: var(--mf-ink-soft);
    text-transform: uppercase;
  }

  @media (max-width: 720px) {
    .serv-grid { padding: 10px 18px 14px; }
    .cols-2 { grid-template-columns: 1fr; column-gap: 0; }
  }
</style>
