---
import BrandMark from './BrandMark.astro';
import WhatsAppCTA from './WhatsAppCTA.astro';
import { t, type Lang, localizedPath } from '~/i18n';

interface Props {
  variant?: 'hero' | 'paper';
  lang?: Lang;
}

const { variant = 'paper', lang = 'es' } = Astro.props;
const isHero = variant === 'hero';

const links = [
  { href: localizedPath('/#unidades', lang), label: t('nav.units', lang) },
  { href: localizedPath('/servicios', lang), label: t('nav.services', lang) },
  { href: localizedPath('/ubicacion', lang), label: t('nav.location', lang) },
  { href: localizedPath('/galeria', lang), label: t('nav.gallery', lang) },
  { href: localizedPath('/faq', lang), label: t('nav.faq', lang) },
];

const currentPath = Astro.url.pathname;
const otherLang: Lang = lang === 'es' ? 'en' : 'es';
const otherLangPath = lang === 'es' ? `/en${currentPath === '/' ? '' : currentPath}` : currentPath.replace(/^\/en/, '') || '/';
const esPath = lang === 'es' ? currentPath : otherLangPath;
const enPath = lang === 'en' ? currentPath : otherLangPath;
---
<nav
  class={`nav ${isHero ? 'nav-hero' : 'nav-paper'}`}
  aria-label="Main navigation"
>
  <a href={localizedPath('/', lang)} class="nav-brand">
    <BrandMark inverted={isHero} size={isHero ? 32 : 30} />
    <span class="nav-name">Refugio del Corazón</span>
  </a>

  <div class="nav-links">
    {links.map(({ href, label }) => (
      <a href={href} class="nav-link">{label}</a>
    ))}
  </div>

  <div class="nav-actions">
    <div class="nav-lang" role="group" aria-label="Language">
      <a href={esPath} class={`nav-lang-btn ${lang === 'es' ? 'on' : ''}`}>ES</a>
      <span class="nav-lang-sep">/</span>
      <a href={enPath} class={`nav-lang-btn ${lang === 'en' ? 'on' : ''}`}>EN</a>
    </div>
    <WhatsAppCTA lang={lang} variant="small" class="nav-cta" />
  </div>

  <button
    class="nav-burger"
    type="button"
    aria-label={t('common.openMenu', lang)}
    aria-expanded="false"
    aria-controls="nav-mobile-menu"
    data-burger
    data-label-open={t('common.openMenu', lang)}
    data-label-close={t('common.closeMenu', lang)}
  >
    <span></span><span></span><span></span>
  </button>
</nav>

<div class="nav-mobile-menu" id="nav-mobile-menu" data-mobile-menu hidden>
  {links.map(({ href, label }) => (
    <a href={href} class="nav-mobile-link">{label}</a>
  ))}
  <div class="nav-mobile-foot">
    <div class="nav-lang">
      <a href={esPath} class={`nav-lang-btn ${lang === 'es' ? 'on' : ''}`}>ES</a>
      <span class="nav-lang-sep">/</span>
      <a href={enPath} class={`nav-lang-btn ${lang === 'en' ? 'on' : ''}`}>EN</a>
    </div>
    <WhatsAppCTA lang={lang} variant="big" fullWidth />
  </div>
</div>

<script>
  const burger = document.querySelector('[data-burger]') as HTMLButtonElement | null;
  const menu = document.querySelector('[data-mobile-menu]') as HTMLDivElement | null;
  if (burger && menu) {
    const labelOpen = burger.dataset.labelOpen ?? 'Open menu';
    const labelClose = burger.dataset.labelClose ?? 'Close menu';
    const setState = (isOpen: boolean) => {
      if (isOpen) {
        menu.removeAttribute('hidden');
        burger.classList.add('open');
        burger.setAttribute('aria-expanded', 'true');
        burger.setAttribute('aria-label', labelClose);
        document.body.style.overflow = 'hidden';
      } else {
        menu.setAttribute('hidden', '');
        burger.classList.remove('open');
        burger.setAttribute('aria-expanded', 'false');
        burger.setAttribute('aria-label', labelOpen);
        document.body.style.overflow = '';
      }
    };
    burger.addEventListener('click', () => setState(menu.hasAttribute('hidden')));
    menu.querySelectorAll('a').forEach(a => a.addEventListener('click', () => setState(false)));
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !menu.hasAttribute('hidden')) setState(false);
    });
  }

  const nav = document.querySelector('.nav-paper') as HTMLElement | null;
  if (nav) {
    const update = () => nav.classList.toggle('is-scrolled', window.scrollY > 4);
    update();
    window.addEventListener('scroll', update, { passive: true });
  }
</script>

<style>
  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 28px;
    gap: 22px;
    position: sticky;
    top: 0;
    z-index: 50;
    transition: background 0.2s, border-color 0.2s;
  }
  .nav-paper {
    background: var(--mf-paper);
    color: var(--mf-ink);
    border-bottom: 1px solid var(--mf-hair);
    transition: background 0.2s, border-color 0.2s, box-shadow 0.2s;
  }
  .nav-paper.is-scrolled {
    box-shadow: 0 6px 18px -14px rgba(27, 26, 22, 0.4);
  }
  .nav-hero {
    background: transparent;
    color: var(--mf-paper);
    border-bottom: 1px solid rgba(244, 240, 230, 0.15);
    position: absolute;
    top: 0; left: 0; right: 0;
    z-index: 5;
  }

  .nav-brand {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: -0.005em;
    color: inherit;
  }
  .nav-name { white-space: nowrap; }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 22px;
    flex: 1;
    justify-content: center;
  }
  .nav-link {
    font-size: 13px;
    font-weight: 500;
    letter-spacing: -0.005em;
    color: inherit;
    opacity: 0.75;
    transition: opacity 0.15s, color 0.15s;
  }
  .nav-link:hover { opacity: 1; }
  .nav-hero .nav-link { opacity: 0.85; }

  .nav-actions { display: flex; align-items: center; gap: 18px; }
  .nav-lang {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-family: var(--mf-font-mono);
    font-size: 11px;
    letter-spacing: 0.06em;
  }
  .nav-lang-btn {
    padding: 3px 5px;
    opacity: 0.55;
    color: inherit;
    transition: opacity 0.15s;
  }
  .nav-lang-btn:hover { opacity: 1; }
  .nav-lang-btn.on {
    opacity: 1;
    font-weight: 700;
    text-decoration: underline;
    text-decoration-color: var(--mf-accent);
    text-underline-offset: 4px;
    text-decoration-thickness: 2px;
  }
  .nav-lang-sep { opacity: 0.4; }

  .nav-cta { padding: 8px 14px !important; font-size: 12px !important; }
  .nav-hero .nav-cta {
    background: var(--mf-paper);
    color: var(--mf-ink);
    box-shadow: none;
  }

  .nav-burger {
    display: none;
    background: transparent;
    border: 0;
    width: 28px;
    height: 22px;
    padding: 0;
    cursor: pointer;
    flex-direction: column;
    justify-content: space-between;
  }
  .nav-burger span {
    display: block;
    height: 2px;
    background: currentColor;
    border-radius: 1px;
    transition: transform 0.2s;
  }
  .nav-burger.open span:nth-child(1) { transform: translateY(10px) rotate(45deg); }
  .nav-burger.open span:nth-child(2) { opacity: 0; }
  .nav-burger.open span:nth-child(3) { transform: translateY(-10px) rotate(-45deg); }

  .nav-mobile-menu {
    position: fixed;
    top: 0; left: 0; right: 0; bottom: 0;
    background: var(--mf-paper);
    z-index: 40;
    padding: 80px 24px 24px;
    flex-direction: column;
    gap: 6px;
  }
  .nav-mobile-menu:not([hidden]) { display: flex; }
  .nav-mobile-menu[hidden] { display: none; }
  .nav-mobile-link {
    padding: 16px 0;
    font-size: 22px;
    font-weight: 600;
    letter-spacing: -0.015em;
    border-bottom: 1px solid var(--mf-hair);
    color: var(--mf-ink);
  }
  .nav-mobile-foot {
    margin-top: auto;
    display: flex;
    flex-direction: column;
    gap: 18px;
    padding-top: 24px;
  }

  @media (max-width: 900px) {
    .nav {
      padding-top: 14px;
      padding-bottom: 14px;
      padding-left: max(18px, env(safe-area-inset-left));
      padding-right: max(18px, env(safe-area-inset-right));
    }
    .nav-links, .nav-actions { display: none; }
    .nav-burger { display: flex; }
    .nav-name { display: none; }
    .nav-mobile-menu {
      padding-left: max(24px, env(safe-area-inset-left));
      padding-right: max(24px, env(safe-area-inset-right));
      padding-bottom: max(24px, env(safe-area-inset-bottom));
    }
  }
</style>
