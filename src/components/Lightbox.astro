---
import { t, type Lang } from '~/i18n';
interface Props { lang?: Lang }
const { lang = 'es' } = Astro.props;
const labels = {
  close: lang === 'en' ? 'Close' : 'Cerrar',
  prev:  lang === 'en' ? 'Previous' : 'Anterior',
  next:  lang === 'en' ? 'Next' : 'Siguiente',
};
---
<div class="lb" id="lightbox" aria-hidden="true" role="dialog" aria-modal="true" aria-label={labels.close}>
  <button type="button" class="lb-close" aria-label={labels.close}>×</button>
  <button type="button" class="lb-nav lb-prev" aria-label={labels.prev}>‹</button>
  <button type="button" class="lb-nav lb-next" aria-label={labels.next}>›</button>
  <figure class="lb-stage">
    <img class="lb-img" src="" alt="" />
    <figcaption class="lb-meta">
      <span class="lb-caption"></span>
      <span class="lb-counter spec-mono"></span>
    </figcaption>
  </figure>
</div>

<script is:inline>
  (function () {
    const lb = document.getElementById('lightbox');
    if (!lb) return;
    const imgEl = lb.querySelector('.lb-img');
    const capEl = lb.querySelector('.lb-caption');
    const ctrEl = lb.querySelector('.lb-counter');
    const btnClose = lb.querySelector('.lb-close');
    const btnPrev = lb.querySelector('.lb-prev');
    const btnNext = lb.querySelector('.lb-next');

    let group = [];
    let idx = 0;
    let lastFocus = null;

    function indexGroup(name) {
      const all = document.querySelectorAll('[data-lb-group="' + name + '"]');
      return Array.from(all).map(el => ({
        el,
        src: el.getAttribute('href') || el.dataset.lbSrc || (el.querySelector('img') && el.querySelector('img').src),
        caption: el.dataset.lbCaption || '',
        alt: (el.querySelector('img') && el.querySelector('img').alt) || ''
      }));
    }

    function render() {
      const item = group[idx];
      if (!item) return;
      imgEl.src = item.src;
      imgEl.alt = item.alt;
      capEl.textContent = item.caption;
      capEl.style.display = item.caption ? '' : 'none';
      ctrEl.textContent = (idx + 1) + ' / ' + group.length;
      const single = group.length <= 1;
      btnPrev.hidden = single;
      btnNext.hidden = single;
    }

    function open(name, startIdx) {
      group = indexGroup(name);
      if (!group.length) return;
      idx = Math.max(0, Math.min(startIdx | 0, group.length - 1));
      lastFocus = document.activeElement;
      lb.setAttribute('aria-hidden', 'false');
      document.documentElement.style.overflow = 'hidden';
      render();
      btnClose.focus();
    }

    function close() {
      lb.setAttribute('aria-hidden', 'true');
      document.documentElement.style.overflow = '';
      imgEl.src = '';
      if (lastFocus && lastFocus.focus) lastFocus.focus();
    }

    function step(delta) {
      if (!group.length) return;
      idx = (idx + delta + group.length) % group.length;
      render();
    }

    document.addEventListener('click', function (e) {
      const trigger = e.target.closest('[data-lb-group]');
      if (trigger) {
        e.preventDefault();
        const name = trigger.getAttribute('data-lb-group');
        const startIdx = parseInt(trigger.dataset.lbIndex || '0', 10);
        open(name, startIdx);
      }
    });

    btnClose.addEventListener('click', close);
    btnPrev.addEventListener('click', function () { step(-1); });
    btnNext.addEventListener('click', function () { step(1); });
    lb.addEventListener('click', function (e) {
      if (e.target === lb) close();
    });

    document.addEventListener('keydown', function (e) {
      if (lb.getAttribute('aria-hidden') === 'true') return;
      if (e.key === 'Escape') close();
      else if (e.key === 'ArrowRight') step(1);
      else if (e.key === 'ArrowLeft') step(-1);
    });

    // Touch swipe
    let touchX = null;
    lb.addEventListener('touchstart', function (e) {
      touchX = e.changedTouches[0].clientX;
    }, { passive: true });
    lb.addEventListener('touchend', function (e) {
      if (touchX === null) return;
      const dx = e.changedTouches[0].clientX - touchX;
      touchX = null;
      if (Math.abs(dx) < 40) return;
      step(dx < 0 ? 1 : -1);
    }, { passive: true });
  })();
</script>

<style>
  .lb {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: rgba(27, 26, 22, 0.94);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.18s ease;
  }
  .lb[aria-hidden="false"] {
    opacity: 1;
    pointer-events: auto;
  }
  .lb-stage {
    margin: 0;
    max-width: 92vw;
    max-height: 88vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
  }
  .lb-img {
    max-width: 92vw;
    max-height: 80vh;
    width: auto;
    height: auto;
    object-fit: contain;
    background: var(--mf-ink);
    border: 1px solid rgba(244, 240, 230, 0.12);
  }
  .lb-meta {
    display: flex;
    align-items: baseline;
    gap: 18px;
    color: var(--mf-paper);
    max-width: 92vw;
  }
  .lb-caption {
    font-size: 13px;
    letter-spacing: -0.005em;
    color: var(--mf-paper);
  }
  .lb-counter {
    color: rgba(244, 240, 230, 0.6);
    font-size: 10.5px;
  }

  .lb-close,
  .lb-nav {
    position: absolute;
    background: rgba(244, 240, 230, 0.08);
    color: var(--mf-paper);
    border: 1px solid rgba(244, 240, 230, 0.18);
    cursor: pointer;
    font-family: var(--mf-font-ui);
    line-height: 1;
    transition: background 0.15s, transform 0.15s;
  }
  .lb-close:hover,
  .lb-nav:hover { background: rgba(244, 240, 230, 0.18); }
  .lb-close:focus-visible,
  .lb-nav:focus-visible { outline: 2px solid var(--mf-accent); outline-offset: 2px; }

  .lb-close {
    top: 18px;
    right: 18px;
    width: 44px;
    height: 44px;
    font-size: 28px;
    font-weight: 400;
    border-radius: 50%;
  }
  .lb-nav {
    top: 50%;
    transform: translateY(-50%);
    width: 52px;
    height: 52px;
    font-size: 30px;
    font-weight: 400;
    border-radius: 50%;
  }
  .lb-nav:hover { transform: translateY(-50%) scale(1.05); }
  .lb-prev { left: 24px; }
  .lb-next { right: 24px; }
  .lb-nav[hidden] { display: none; }

  @media (max-width: 720px) {
    .lb-close { top: 12px; right: 12px; width: 38px; height: 38px; font-size: 22px; }
    .lb-nav { width: 42px; height: 42px; font-size: 24px; }
    .lb-prev { left: 10px; }
    .lb-next { right: 10px; }
    .lb-img { max-height: 72vh; }
    .lb-meta { flex-direction: column; gap: 4px; align-items: center; text-align: center; }
  }
</style>
