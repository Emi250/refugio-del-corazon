---
import Base from '~/layouts/Base.astro';
import Hero from '~/components/Hero.astro';
import SectionBar from '~/components/SectionBar.astro';
import UnitRow from '~/components/UnitRow.astro';
import GalleryStrip from '~/components/GalleryStrip.astro';
import ServiceList from '~/components/ServiceList.astro';
import LocationBlock from '~/components/LocationBlock.astro';
import ReviewsBlock from '~/components/ReviewsBlock.astro';
import FAQPreview from '~/components/FAQPreview.astro';
import CTABlock from '~/components/CTABlock.astro';
import Lightbox from '~/components/Lightbox.astro';
import { t } from '~/i18n';
import { getCollection } from 'astro:content';

const lang = 'es' as const;
const allUnits = await getCollection('unidades', ({ data }) => data.lang === 'es');
const units = allUnits.sort((a, b) => a.data.order - b.data.order);
---
<Base
  title="Refugio del Corazón · Alquiler temporario en Capilla del Monte, Córdoba"
  description="Cuatro departamentos de alquiler temporario en Río Negro 64, Capilla del Monte. A 800 m del centro y 2,3 km del Cerro Uritorco. Reservá por WhatsApp."
  navVariant="hero"
  preloadImage="/cerro%20uritorco.jpg"
>
  <Hero lang={lang} />

  <section id="unidades">
    <SectionBar no="1" title={t('sections.units', lang)} meta={t('sections.unitsMeta', lang)} />
    {units.map((unit, i) => (
      <UnitRow unit={unit} lang={lang} align={i % 2 === 0 ? 'left' : 'right'} />
    ))}
  </section>

  <section id="galeria">
    <SectionBar no="2" title={t('sections.gallery', lang)} meta={t('sections.galleryMeta', lang)} metaHref="/galeria" />
    <GalleryStrip lang={lang} />
  </section>

  <section id="servicios">
    <SectionBar no="3" title={t('sections.services', lang)} meta={t('sections.servicesMeta', lang)} metaHref="/servicios" background="paper-2" />
    <div class="bg-paper-2 services-wrap">
      <ServiceList lang={lang} />
    </div>
  </section>

  <section id="ubicacion">
    <SectionBar no="4" title={t('sections.location', lang)} meta={t('sections.locationMeta', lang)} metaHref="/ubicacion" />
    <LocationBlock lang={lang} />
  </section>

  <ReviewsBlock lang={lang} />

  <section id="faq">
    <SectionBar no="5" title={t('sections.faq', lang)} meta={t('sections.faqMeta', lang)} metaHref="/faq" />
    <FAQPreview lang={lang} limit={5} />
  </section>

  <CTABlock lang={lang} />
  <Lightbox lang={lang} />
</Base>

<style>
  .services-wrap {
    background: var(--mf-paper-2);
    padding-bottom: 28px;
    border-bottom: 1.5px solid var(--mf-ink);
  }
  .bg-paper-2 { background: var(--mf-paper-2); }
</style>
