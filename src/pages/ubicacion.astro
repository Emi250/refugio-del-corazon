---
import Base from '~/layouts/Base.astro';
import BigHeader from '~/components/BigHeader.astro';
import CTABlock from '~/components/CTABlock.astro';
import { t } from '~/i18n';
import { getCollection } from 'astro:content';
import { BUSINESS } from '~/utils/seo';

const lang = 'es' as const;
const nearGroups = await getCollection('near');

const origins = [
  {
    name: 'Desde Córdoba Capital',
    distance: '105 km',
    time: '1h 45min',
    steps: ['Ruta E-53 hasta La Falda', 'Continuar por Ruta 38 hacia Cosquín', 'Tomar Ruta 38 norte hasta Capilla del Monte'],
  },
  {
    name: 'Desde Buenos Aires',
    distance: '780 km',
    time: '9h en auto',
    steps: ['Autopista hasta Córdoba', 'Continuar por Ruta E-53 a Capilla del Monte', 'O vuelo a Córdoba + 2h en auto'],
  },
  {
    name: 'Desde Rosario',
    distance: '460 km',
    time: '5h en auto',
    steps: ['Autovía 9 hasta Villa María', 'Ruta 158 hasta Río Tercero', 'Ruta E-55 hacia las Sierras'],
  },
];

const clima = [
  { k: 'VERANO', m: 'Dic · Ene · Feb', t: '28° / 16°', n: 'Calor seco, noches frescas. Ideal para río.' },
  { k: 'OTOÑO', m: 'Mar · Abr · May', t: '22° / 8°', n: 'Días templados, mucha luz dorada.' },
  { k: 'INVIERNO', m: 'Jun · Jul · Ago', t: '15° / 2°', n: 'Frío seco.' },
  { k: 'PRIMAVERA', m: 'Sep · Oct · Nov', t: '24° / 10°', n: 'La mejor época. Verde y florido.' },
];
---
<Base
  title="Dónde alojarse en Capilla del Monte · Río Negro 64 | Refugio del Corazón"
  description="Cómo llegar a Capilla del Monte desde Córdoba Capital, Buenos Aires o Rosario. Distancias al Cerro Uritorco, El Zapato, Los Terrones. Clima por estación."
  ogType="article"
>
  <BigHeader
    kicker="03 · UBICACIÓN"
    title="Rio Negro 64"
    meta="CAPILLA DEL MONTE · CÓRDOBA"
    blurb="A 800 m del centro, 1 km de la Terminal de Ómnibus y 2,3 km del Cerro Uritorco. Un punto estratégico para descansar y recorrer."
  />

  <section class="loc-map-wrap">
    <div class="loc-map">
      <iframe
        class="loc-iframe"
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3424.7409753491656!2d-64.52738632470985!3d-30.865926269856615!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x942d8df5395e1ead%3A0xa4dc4f4097366c7f!2sR%C3%ADo%20Negro%2064%2C%20X5184%20Capilla%20del%20Monte%2C%20C%C3%B3rdoba!5e0!3m2!1ses!2sar!4v1779458249290!5m2!1ses!2sar"
        loading="lazy"
        allowfullscreen
        referrerpolicy="no-referrer-when-downgrade"
        title="Rio Negro 64, Capilla del Monte"
      ></iframe>
      <article class="loc-card frame-card">
        <span class="kicker">PIN</span>
        <h3>Rio Negro 64</h3>
        <p>Calle tranquila, parking incluido, a pasos de la peatonal y el centro.</p>
        <div class="loc-chips">
          <span class="chip">Centro · 800 m</span>
          <span class="chip">Terminal · 1 km</span>
          <span class="chip">Uritorco · 2,3 km</span>
          <a class="chip chip-maps" href="https://maps.app.goo.gl/bq9HnLudj3jFDMWz9" target="_blank" rel="noopener">Ver en Google Maps ↗</a>
        </div>
      </article>
    </div>
  </section>

  <section class="block">
    <div class="block-head">
      <h2>{t('location.howToGet', lang)}</h2>
      <span class="spec-mono">3 ORÍGENES</span>
    </div>
    <div class="origins-grid">
      {origins.map(o => (
        <div class="origin">
          <span class="kicker">{o.name}</span>
          <div class="origin-dist display-no display-sm">{o.distance}</div>
          <div class="origin-time spec-mono">≈ {o.time}</div>
          <ol class="origin-steps">
            {o.steps.map(s => <li>{s}</li>)}
          </ol>
        </div>
      ))}
    </div>
  </section>

  <section class="block bg-paper-2">
    <div class="block-head">
      <h2>{t('location.nearby', lang)}</h2>
      <span class="spec-mono">MEJOR PUNTUADOS</span>
    </div>
    <div class="near-grid">
      {nearGroups.map(g => (
        <div class="near-col">
          <div class="near-cat kicker">{g.data.category}</div>
          {g.data.items.map(it => (
            <div class="near-row">
              <div>
                <div class="near-name">{it.name}</div>
                {it.note && <div class="near-note">{it.note}</div>}
              </div>
              <span class="near-dist">{it.distance}</span>
            </div>
          ))}
        </div>
      ))}
    </div>
  </section>

  <section class="block">
    <div class="block-head">
      <h2>{t('location.weather', lang)}</h2>
      <span class="spec-mono">CUÁNDO VISITAR</span>
    </div>
    <div class="clima-grid">
      {clima.map(c => (
        <div class="clima-cell">
          <div class="clima-k">{c.k}</div>
          <div class="clima-m">{c.m}</div>
          <div class="clima-t display-no display-sm">{c.t}</div>
          <div class="clima-n">{c.n}</div>
        </div>
      ))}
    </div>
  </section>

  <CTABlock lang={lang} background="paper-2" mapsUrl={BUSINESS.mapsUrl} />
</Base>

<style>
  .bg-paper-2 { background: var(--mf-paper-2); }
  .chip-maps { background: var(--mf-accent); color: var(--mf-paper); border-color: var(--mf-accent); }
  .chip-maps:hover { background: var(--mf-ink); border-color: var(--mf-ink); color: var(--mf-paper); }
  .loc-map-wrap { background: var(--mf-paper-2); border-bottom: 1.5px solid var(--mf-ink); }
  .loc-map {
    position: relative;
    min-height: 480px;
    background-color: var(--mf-stone);
    overflow: hidden;
  }
  .loc-iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
    z-index: 1;
    display: block;
  }
  .loc-card {
    position: absolute;
    left: 32px;
    top: 32px;
    padding: 24px 26px;
    max-width: 360px;
    z-index: 3;
  }
  .loc-card h3 {
    font-size: 28px;
    margin: 12px 0 10px;
    letter-spacing: -0.02em;
    font-weight: 700;
  }
  .loc-card p {
    font-size: 13.5px;
    line-height: 1.55;
    color: var(--mf-ink-soft);
    margin: 0 0 14px;
  }
  .loc-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .block {
    padding: 36px 28px;
    border-bottom: 1.5px solid var(--mf-ink);
    background: var(--mf-paper);
  }
  .block-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    border-bottom: 1px solid var(--mf-hair);
    padding-bottom: 14px;
    margin-bottom: 22px;
  }
  .block-head h2 {
    font-size: 26px;
    letter-spacing: -0.025em;
    font-weight: 700;
  }

  .origins-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    border: 1px solid var(--mf-ink);
  }
  .origin {
    padding: 22px 24px;
    border-right: 1px solid var(--mf-hair);
  }
  .origin:last-child { border-right: 0; }
  .origin-dist { margin-top: 14px; }
  .origin-time { margin-top: 6px; }
  .origin-steps {
    padding-left: 20px;
    margin: 18px 0 0;
    font-size: 13px;
    line-height: 1.55;
    color: var(--mf-ink-soft);
  }
  .origin-steps li { margin-bottom: 5px; }

  .near-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0 40px;
  }
  .near-cat {
    padding: 0 0 10px;
    border-top: 1px solid var(--mf-hair);
    padding-top: 18px;
    letter-spacing: 0.18em;
  }
  .near-row {
    display: flex;
    justify-content: space-between;
    padding: 11px 0;
    border-top: 1px solid var(--mf-hair);
    align-items: flex-start;
    gap: 10px;
  }
  .near-name { font-size: 13.5px; font-weight: 500; letter-spacing: -0.005em; }
  .near-note {
    font-size: 11px;
    color: var(--mf-ink-soft);
    margin-top: 2px;
  }
  .near-dist { font-size: 13px; font-weight: 600; }

  .clima-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    border: 1px solid var(--mf-ink);
  }
  .clima-cell {
    padding: 20px 22px;
    border-right: 1px solid var(--mf-hair);
  }
  .clima-cell:last-child { border-right: 0; }
  .clima-k {
    font-family: var(--mf-font-mono);
    font-size: 10.5px;
    font-weight: 500;
    letter-spacing: 0.14em;
    color: var(--mf-ink-soft);
    text-transform: uppercase;
  }
  .clima-m { font-size: 13px; font-weight: 600; margin-top: 10px; }
  .clima-t { margin-top: 14px; }
  .clima-n {
    font-size: 12px;
    line-height: 1.45;
    color: var(--mf-ink-soft);
    margin-top: 10px;
  }

  @media (max-width: 900px) {
    .origins-grid, .clima-grid { grid-template-columns: 1fr; }
    .origin, .clima-cell { border-right: 0; border-bottom: 1px solid var(--mf-hair); }
    .origin:last-child, .clima-cell:last-child { border-bottom: 0; }
    .near-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 720px) {
    .block { padding: 22px 18px; }
    .loc-map { min-height: auto; padding: 18px; aspect-ratio: 4/3; }
    .loc-card { position: static; max-width: none; }
  }
</style>
