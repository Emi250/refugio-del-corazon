---
import Base from '~/layouts/Base.astro';
import BigHeader from '~/components/BigHeader.astro';
import ServiceList from '~/components/ServiceList.astro';
import CTABlock from '~/components/CTABlock.astro';
import { t, localizedPath } from '~/i18n';
import { getCollection } from 'astro:content';

const lang = 'es' as const;
const units = (await getCollection('unidades', ({ data }) => data.lang === 'es'))
  .sort((a, b) => a.data.order - b.data.order);

const incluidos = [
  { k: 'WiFi fibra óptica (300 megas)', v: 'INCLUIDO' },
  { k: 'Cocina equipada + heladera con freezer', v: 'INCLUIDO' },
  { k: 'Ropa de cama', v: 'INCLUIDO' },
  { k: 'Toallas', v: 'INCLUIDO' },
  { k: 'Aire acondicionado', v: 'INCLUIDO' },
  { k: 'Cochera privada (sujeto a disponibilidad)', v: 'INCLUIDO' },
  { k: 'Parrilla', v: 'INCLUIDO' },
  { k: 'Patio interno compartido', v: 'INCLUIDO' },
  { k: 'Smart TV con streaming', v: 'INCLUIDO' },
  { k: 'Check-in con anfitrión', v: 'INCLUIDO' },
];

const noTenemos = [
  { k: 'Pileta', v: 'En la base del cerro hay ríos para bañarse.' },
  { k: 'Servicio de habitación', v: 'Somos un alquiler temporario, no un hotel.' },
  { k: 'Desayuno incluido', v: 'La cocina equipada te permite armar tu propio ritmo.' },
  { k: 'TV por cable', v: 'Pero tenemos Smart TV con Netflix (cuenta incluida sin costo), YouTube y demás apps de streaming.' },
  { k: 'Limpieza', v: 'Te dejamos artículos de limpieza. Si tu estadía es de más de 7 noches, ofrecemos limpieza sin costo adicional.' },
];
---
<Base
  title="Servicios incluidos · Alquiler temporario en Capilla del Monte | Refugio del Corazón"
  description="Todo lo que incluye tu estadía en Capilla del Monte: cocina equipada, ropa de cama, WiFi fibra 300 megas, aire acondicionado, cochera y parrilla."
>
  <BigHeader
    kicker="02 · SERVICIOS"
    title="Todo incluido"
    meta="04 DEPARTAMENTOS · CAPILLA DEL MONTE"
    blurb="Vení con lo justo. Cada departamento está equipado para que llegues, dejes la valija y arranques a descansar."
  />

  <section class="serv-section">
    <div class="serv-head">
      <h2>Lo que incluye tu estadía</h2>
      <span class="spec-mono">10 ÍTEMS</span>
    </div>
    <ServiceList lang={lang} items={incluidos} />
  </section>

  <section class="serv-section bg-paper-2">
    <div class="serv-head">
      <h2>{t('services.noTenemosTitle', lang)}</h2>
      <span class="spec-mono">TRANSPARENCIA</span>
    </div>
    <p class="serv-lead">{t('services.noTenemosLead', lang)}</p>
    <div class="nt-grid">
      {noTenemos.map(it => (
        <div class="nt-row">
          <span class="nt-x">×</span>
          <div>
            <div class="nt-k">{it.k}</div>
            <div class="nt-v">{it.v}</div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="serv-units">
    <header class="serv-units-head">
      <span class="kicker">{t('servicesPage.browseKicker', lang)}</span>
      <h2>{t('servicesPage.browseTitle', lang)}</h2>
    </header>
    <div class="serv-units-grid">
      {units.map(u => (
        <a href={localizedPath(`/unidades/${u.slug}`, lang)} class="serv-units-item">
          <div class="display-no serv-units-no">0{u.data.order}</div>
          <div class="serv-units-info">
            <div class="serv-units-name">{u.data.name}</div>
            <div class="serv-units-meta spec-mono">{u.data.specs.capacidad} · {u.data.specs.metros}</div>
          </div>
          <span class="serv-units-arrow">→</span>
        </a>
      ))}
    </div>
  </section>

  <CTABlock lang={lang} />
</Base>

<style>
  .serv-section {
    padding: 30px 28px;
    border-bottom: 1.5px solid var(--mf-ink);
    background: var(--mf-paper);
  }
  .bg-paper-2 { background: var(--mf-paper-2); }
  .serv-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    border-bottom: 1px solid var(--mf-hair);
    padding-bottom: 14px;
    margin-bottom: 14px;
  }
  .serv-head h2 {
    font-size: 26px;
    line-height: 1.05;
    letter-spacing: -0.025em;
    font-weight: 700;
  }
  .serv-lead {
    font-size: 14px;
    line-height: 1.55;
    color: var(--mf-ink-soft);
    margin: 0 0 18px;
    max-width: 60ch;
  }
  .nt-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0 40px;
  }
  .nt-row {
    display: grid;
    grid-template-columns: 18px 1fr;
    gap: 12px;
    padding: 14px 0;
    border-bottom: 1px solid var(--mf-hair);
    align-items: flex-start;
  }
  .nt-x {
    font-size: 18px;
    color: var(--mf-ink-soft);
    line-height: 1;
  }
  .nt-k {
    font-size: 14.5px;
    font-weight: 500;
    letter-spacing: -0.005em;
  }
  .nt-v {
    font-size: 12.5px;
    line-height: 1.5;
    color: var(--mf-ink-soft);
    margin-top: 4px;
  }
  .serv-units {
    padding: 30px 28px;
    background: var(--mf-paper);
    border-bottom: 1.5px solid var(--mf-ink);
  }
  .serv-units-head { margin-bottom: 18px; }
  .serv-units-head .kicker { display: block; margin-bottom: 8px; }
  .serv-units-head h2 {
    font-size: 28px;
    line-height: 1;
    letter-spacing: -0.025em;
    font-weight: 700;
  }
  .serv-units-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border: 1px solid var(--mf-ink);
  }
  .serv-units-item {
    padding: 22px 24px;
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 18px;
    border-right: 1px solid var(--mf-hair);
    color: var(--mf-ink);
    transition: background 0.15s, color 0.15s;
  }
  .serv-units-item:last-child { border-right: 0; }
  .serv-units-item:hover { background: var(--mf-paper-2); color: var(--mf-accent); }
  .serv-units-no { font-size: 36px; }
  .serv-units-name {
    font-size: 16px;
    font-weight: 600;
    letter-spacing: -0.015em;
  }
  .serv-units-meta { margin-top: 4px; }
  .serv-units-arrow { font-size: 16px; }

  @media (max-width: 900px) {
    .serv-units-grid { grid-template-columns: 1fr 1fr; }
    .serv-units-item:nth-child(2n) { border-right: 0; }
    .serv-units-item { border-bottom: 1px solid var(--mf-hair); }
    .serv-units-item:nth-child(n+3) { border-bottom: 0; }
  }
  @media (max-width: 720px) {
    .serv-section, .serv-units { padding: 22px 18px; }
    .nt-grid { grid-template-columns: 1fr; }
    .serv-units-grid { grid-template-columns: 1fr; }
    .serv-units-item { border-right: 0; border-bottom: 1px solid var(--mf-hair); }
    .serv-units-item:last-child { border-bottom: 0; }
    .serv-units-head h2 { font-size: 22px; }
  }
</style>
